# ===== 后端环境变量示例 =====
# 复制本文件为 .env（或直接在系统/IDE 运行配置中设置以下环境变量），并填入你的真实值。
# 注意：Spring Boot 默认不会自动加载 .env 文件，请通过以下任一方式让变量生效：
#   1) IDEA 运行配置 -> Environment variables 中逐条填入；
#   2) 命令行启动前 export（macOS/Linux）或 $env:（PowerShell）设置；
#   3) 借助 spring-dotenv 等插件加载 .env（可选）。
# application.yml 中已为每项配置了本地默认值，仅需覆盖与本机不同的项。

# --- 数据库 ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=campus_club_db
DB_USERNAME=root
DB_PASSWORD=your-mysql-password

# --- 大模型 API（兼容 OpenAI 格式，支持 DeepSeek / 通义千问 / OpenAI 等）---
# 获取 DeepSeek Key: https://platform.deepseek.com/api_keys
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_API_KEY=your-api-key-here
AI_MODEL=deepseek-chat
